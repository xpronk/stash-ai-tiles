name: AI Services & Unlock Check
desc: |-
  AI组(GPT/YouTube/Gemini/Claude/Grok/Poe)通过 cloudflare.com/cdn-cgi/trace 取地区。
  需在 Stash Ai 规则中添加: DOMAIN,cloudflare.com,Ai  +  DOMAIN,www.cloudflare.com,Ai
  Netflix 用自身 X-Originating-Url 取地区。
  其余服务仅显示可用性。

tiles:
  - name: GPT-Check
    title: ChatGPT
    icon: https://icons.duckduckgo.com/ip3/chatgpt.com.ico
    collapsed: true
    url: https://chatgpt.com
  - name: YouTube-Check
    title: YouTube
    icon: https://icons.duckduckgo.com/ip3/youtube.com.ico
    collapsed: true
    url: https://www.youtube.com
  - name: Netflix-Check
    title: Netflix
    icon: https://icons.duckduckgo.com/ip3/netflix.com.ico
    collapsed: true
    url: https://www.netflix.com
  - name: TikTok-Check
    title: TikTok
    icon: https://icons.duckduckgo.com/ip3/tiktok.com.ico
    collapsed: true
    url: https://www.tiktok.com
  - name: Gemini-Check
    title: Gemini
    icon: https://icons.duckduckgo.com/ip3/gemini.google.com.ico
    collapsed: true
    url: https://gemini.google.com
  - name: Claude-Check
    title: Claude
    icon: https://icons.duckduckgo.com/ip3/claude.ai.ico
    collapsed: true
    url: https://claude.ai
  - name: Grok-Check
    title: Grok
    icon: https://icons.duckduckgo.com/ip3/grok.com.ico
    collapsed: true
    url: https://grok.com
  - name: Instagram-Check
    title: Instagram
    icon: https://icons.duckduckgo.com/ip3/instagram.com.ico
    collapsed: true
    url: https://www.instagram.com
  - name: Twitter-Check
    title: X/Twitter
    icon: https://icons.duckduckgo.com/ip3/x.com.ico
    collapsed: true
    url: https://x.com
  - name: Poe-Check
    title: Poe
    icon: https://icons.duckduckgo.com/ip3/poe.com.ico
    collapsed: true
    url: https://poe.com

script-providers:
  GPT-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/gpt.js?v=2
    interval: 86400
  YouTube-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/youtube.js?v=2
    interval: 86400
  Netflix-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/netflix.js?v=2
    interval: 86400
  TikTok-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/tiktok.js?v=2
    interval: 86400
  Gemini-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/gemini.js?v=2
    interval: 86400
  Claude-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/claude.js?v=2
    interval: 86400
  Grok-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/grok.js?v=2
    interval: 86400
  Instagram-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/instagram.js?v=2
    interval: 86400
  Twitter-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/twitter.js?v=2
    interval: 86400
  Poe-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/poe.js?v=2
    interval: 86400