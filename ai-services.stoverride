name: AI Services & Unlock Check
desc: |-
  AI组(GPT/YouTube/Gemini/Claude/Grok/Poe)通过 cloudflare.com/cdn-cgi/trace 取地区。
  需在 Stash Ai 规则中添加: DOMAIN,cloudflare.com,Ai  +  DOMAIN,www.cloudflare.com,Ai
  Netflix 用自身 X-Originating-Url 取地区。
  其余服务仅显示可用性。

tiles:
  - name: GPT-Check
    title: ChatGPT
    icon: https://chatgpt.com/favicon.ico
    collapsed: true
    url: https://chatgpt.com
  - name: YouTube-Check
    title: YouTube
    icon: https://www.youtube.com/favicon.ico
    collapsed: true
    url: https://www.youtube.com
  - name: Netflix-Check
    title: Netflix
    icon: https://www.netflix.com/favicon.ico
    collapsed: true
    url: https://www.netflix.com
  - name: TikTok-Check
    title: TikTok
    icon: https://www.tiktok.com/favicon.ico
    collapsed: true
    url: https://www.tiktok.com
  - name: Gemini-Check
    title: Gemini
    icon: https://www.google.com/favicon.ico
    collapsed: true
    url: https://gemini.google.com
  - name: Claude-Check
    title: Claude
    icon: https://claude.ai/favicon.ico
    collapsed: true
    url: https://claude.ai
  - name: Grok-Check
    title: Grok
    icon: https://grok.com/favicon.ico
    collapsed: true
    url: https://grok.com
  - name: Instagram-Check
    title: Instagram
    icon: https://www.instagram.com/favicon.ico
    collapsed: true
    url: https://www.instagram.com
  - name: Twitter-Check
    title: X/Twitter
    icon: https://x.com/favicon.ico
    collapsed: true
    url: https://x.com
  - name: Poe-Check
    title: Poe
    icon: https://poe.com/favicon.ico
    collapsed: true
    url: https://poe.com

script-providers:
  GPT-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/gpt.js
    interval: 86400
  YouTube-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/youtube.js
    interval: 86400
  Netflix-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/netflix.js
    interval: 86400
  TikTok-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/tiktok.js
    interval: 86400
  Gemini-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/gemini.js
    interval: 86400
  Claude-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/claude.js
    interval: 86400
  Grok-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/grok.js
    interval: 86400
  Instagram-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/instagram.js
    interval: 86400
  Twitter-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/twitter.js
    interval: 86400
  Poe-Check:
    url: https://raw.githubusercontent.com/xpronk/stash-ai-tiles/main/script/v2/poe.js
    interval: 86400