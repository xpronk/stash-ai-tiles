name: AI Services & Unlock Check
desc: 检测 GPT、YouTube、Netflix、TikTok、Gemini、Claude、Grok、Bilibili 港澳台、Bahamut、Instagram、X/Twitter、Poe 可用性，并显示出口国家。

tiles:
  - name: GPT-Check
    interval: 600
    title: ChatGPT
    content: 检测中…
    icon: https://chatgpt.com/favicon.ico
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://chatgpt.com
  - name: YouTube-Check
    interval: 600
    title: YouTube
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=youtube.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://www.youtube.com
  - name: Netflix-Check
    interval: 600
    title: Netflix
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=netflix.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://www.netflix.com
  - name: TikTok-Check
    interval: 600
    title: TikTok
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=tiktok.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://www.tiktok.com
  - name: Gemini-Check
    interval: 600
    title: Gemini
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=gemini.google.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://gemini.google.com
  - name: Claude-Check
    interval: 600
    title: Claude
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=claude.ai&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://claude.ai
  - name: Grok-Check
    interval: 600
    title: Grok
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=grok.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://grok.com
  - name: Bilibili-HMT-Check
    interval: 600
    title: Bilibili 港澳台
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=bilibili.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://www.bilibili.com
  - name: Bahamut-Check
    interval: 600
    title: Bahamut 动画疯
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=ani.gamer.com.tw&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://ani.gamer.com.tw
  - name: Instagram-Check
    interval: 600
    title: Instagram
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=instagram.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://www.instagram.com
  - name: Twitter-Check
    interval: 600
    title: X / Twitter
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=x.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://x.com
  - name: Poe-Check
    interval: 600
    title: Poe
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=poe.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://poe.com

script-providers:
  GPT-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/gpt.js
    interval: 86400
  YouTube-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/youtube.js
    interval: 86400
  Netflix-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/netflix.js
    interval: 86400
  TikTok-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/tiktok.js
    interval: 86400
  Gemini-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/gemini.js
    interval: 86400
  Claude-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/claude.js
    interval: 86400
  Grok-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/grok.js
    interval: 86400
  Bilibili-HMT-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles@main/script/bilibili-hmt.js
