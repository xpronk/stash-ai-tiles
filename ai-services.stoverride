name: AI Services Check
desc: 检测 Claude、Gemini、Perplexity、Grok、DeepSeek、Poe 等服务可用性。

tiles:
  - name: Claude-Check
    interval: 600
    title: Claude
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=claude.ai&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://claude.ai
  - name: Gemini-Check
    interval: 600
    title: Gemini
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=gemini.google.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://gemini.google.com
  - name: Perplexity-Check
    interval: 600
    title: Perplexity
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=perplexity.ai&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://www.perplexity.ai
  - name: Grok-Check
    interval: 600
    title: Grok
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=grok.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://grok.com
  - name: DeepSeek-Check
    interval: 600
    title: DeepSeek
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=deepseek.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://chat.deepseek.com
  - name: Poe-Check
    interval: 600
    title: Poe
    content: 检测中…
    icon: https://www.google.com/s2/favicons?domain=poe.com&sz=64
    backgroundColor: '#8A1538'
    collapsed: true
    url: https://poe.com

script-providers:
  Claude-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles/script/claude.js
    interval: 86400
  Gemini-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles/script/gemini.js
    interval: 86400
  Perplexity-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles/script/perplexity.js
    interval: 86400
  Grok-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles/script/grok.js
    interval: 86400
  DeepSeek-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles/script/deepseek.js
    interval: 86400
  Poe-Check:
    url: https://fastly.jsdelivr.net/gh/xpronk/stash-ai-tiles/script/poe.js
    interval: 86400
